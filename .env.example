GREYTHR_URL=https://yourcompany.greythr.com/
LOGIN_ID=your_login_id
PASSWORD=your_password

# Comma-separated YYYY-MM-DD dates to skip
LEAVE_DATES=2026-07-20,2026-08-15,2026-09-14,2026-10-02,2026-10-21,2026-11-09,2026-12-25

OFFICE_START_HOUR=9
OFFICE_START_MINUTE=30
OFFICE_END_HOUR=18
OFFICE_END_MINUTE=30

# Max random delay (in minutes) added before sign-in/out to look natural
BUFFER_MAX_MINUTES=10

# Set to false to show the browser while debugging
HEADLESS=true
